OPENAI_API_KEY=
# Optional: OpenAI-compatible gateway (also respected by the OpenAI SDK when not using UNI_AGENT_ overrides)
OPENAI_BASE_URL=

UNI_AGENT_MODEL_NAME=openai:gpt-4.1-mini
# OpenAI-compatible gateway (custom base URL + key), e.g. internal Qwen route:
# UNI_AGENT_MODEL_NAME=openai:qwen3.5-plus
# UNI_AGENT_OPENAI_BASE_URL=https://example.com/your/service/v1
# UNI_AGENT_OPENAI_API_KEY=your-secret
UNI_AGENT_OPENAI_BASE_URL=
UNI_AGENT_OPENAI_API_KEY=

UNI_AGENT_WORKSPACE=.
# Memory defaults to <WORKSPACE>/.uni-agent/memory (not shell cwd). Set only to override.
# UNI_AGENT_MEMORY_DIR=custom_memory
UNI_AGENT_SKILLS_DIR=skills
# Task run JSON logs and interactive client session files (default under .uni-agent/)
UNI_AGENT_TASK_LOG_DIR=.uni-agent/runs
UNI_AGENT_SESSION_DIR=.uni-agent/sessions
# Local memory (uni-agent client idle flush + memory_search tool); under .gitignored .uni-agent/ by default
UNI_AGENT_MEMORY_DIR=.uni-agent/memory
# Optional CA bundle for urllib-based HTTPS tools such as http_fetch / web_search.
# Relative paths resolve under UNI_AGENT_WORKSPACE.
# UNI_AGENT_CA_BUNDLE=certs/corporate-root.pem
# Insecure: disable TLS certificate verification for urllib-based HTTPS tools.
UNI_AGENT_SKIP_TLS_VERIFY=true
# Prefer UNI_AGENT_CA_BUNDLE when possible.
# UNI_AGENT_SKIP_TLS_VERIFY=false
UNI_AGENT_MEMORY_EXTRACT_ENABLED=true
UNI_AGENT_MEMORY_IDLE_EXTRACT_SECONDS=20
# memory_search: LLM keyword expansion + L0 match + L1 synthesis (disable for offline/substring-only)
UNI_AGENT_MEMORY_SEARCH_USE_LLM=true
UNI_AGENT_MEMORY_SEARCH_MAX_HITS=12
UNI_AGENT_LOG_LEVEL=INFO

# LLM system prompts (optional). Built-in defaults live in uni_agent.agent.system_prompts.
# UNI_AGENT_GLOBAL_SYSTEM_PROMPT=You are Uni-Agent: a careful coding assistant.
# UNI_AGENT_PLANNER_INSTRUCTIONS=
# UNI_AGENT_CONCLUSION_SYSTEM_PROMPT=

# Replan loop: stop after this many failed rounds (plan+execute batch not fully successful)
UNI_AGENT_ORCHESTRATOR_MAX_FAILED_ROUNDS=5

# After each batch where all steps completed, ask an LLM whether the user task is satisfied; if not, re-plan with feedback (extra LLM calls)
UNI_AGENT_PLAN_GOAL_CHECK_ENABLED=true
# Max re-plan attempts triggered by goal check when the answer is "not satisfied" (0 = fail on first "not satisfied" without an extra re-plan)
# UNI_AGENT_PLAN_GOAL_CHECK_MAX_REPLAN_ROUNDS=3
# Optional override for the goal-check system prompt (default in agent/system_prompts.py)
# UNI_AGENT_PLAN_GOAL_CHECK_SYSTEM_PROMPT=

# 可观测：可选推送流式事件到 Langfuse（需安装 langfuse 并配置凭据）
# UNI_AGENT_OBSERVABILITY_LANGFUSE_ENABLED=false
# UNI_AGENT_OBSERVABILITY_LANGFUSE_HOST=
# UNI_AGENT_OBSERVABILITY_LANGFUSE_PUBLIC_KEY=
# UNI_AGENT_OBSERVABILITY_LANGFUSE_SECRET_KEY=
# UNI_AGENT_OBSERVABILITY_LANGFUSE_DEBUG=false
# UNI_AGENT_OBSERVABILITY_LANGFUSE_TRACE_NAME=uni-agent-run
# UNI_AGENT_OBSERVABILITY_LANGFUSE_TRACE_INPUT_MAX_CHARS=4000

# Sub-agent (delegate_task): optional child replan cap; unset = same as ORCHESTRATOR_MAX_FAILED_ROUNDS
# UNI_AGENT_DELEGATE_MAX_FAILED_ROUNDS=3
# Child tool profile: full | readonly (readonly = file_read, search_workspace, memory_search, command_lookup only)
# UNI_AGENT_DELEGATE_TOOL_PROFILE=full
